@model FactChecker.Web.Models.ClaimsHeaderModel

<h3 style="margin-top:1.5rem;margin-bottom:.5rem">
    @(Model.IsComplete ? "Fact-checked" : "Fact-checking") @Model.Count claim@(Model.Count == 1 ? "" : "s")
    @if (!Model.IsComplete && Model.Count > 0)
    {
        <progress value="@Model.VerifiedCount" max="@Model.Count"
                  style="width:8rem;margin-left:.75rem;vertical-align:middle"></progress>
        <span style="font-size:.8rem;font-weight:normal;margin-left:.4rem">@Model.VerifiedCount / @Model.Count</span>
    }
</h3>
