@model ContentDomain

@{
    var (label, bg, fg) = Model switch
    {
        ContentDomain.News    => ("News", "#cce5ff", "#004085"),
        ContentDomain.Science => ("Science", "#d1ecf1", "#0c5460"),
        ContentDomain.Finance => ("Finance", "#fff3cd", "#856404"),
        ContentDomain.Health  => ("Health", "#f8d7da", "#721c24"),
        _                     => ("General", "#e2e3e5", "#383d41")
    };
}

<small><span class="badge" style="background:@bg;color:@fg">@label</span></small>
