@model VideoInfo

<article style="margin-bottom:1rem">
    <div style="display:flex;gap:1rem;align-items:flex-start">
        @if (Model.ThumbnailUrl is not null)
        {
            <img src="@Model.ThumbnailUrl" alt="Thumbnail"
                 style="width:160px;height:90px;object-fit:cover;border-radius:.375rem;flex-shrink:0" />
        }
        <div>
            <h2 style="margin:0 0 .25rem">@Model.Title</h2>
            <p style="margin:0;color:var(--pico-muted-color)">
                @Model.Channel
                &nbsp;·&nbsp;
                @Model.Duration.ToString(@"h\:mm\:ss", System.Globalization.CultureInfo.InvariantCulture)
            </p>
            <small>
                <a href="@Model.Url" target="_blank" rel="noopener">Watch on YouTube ↗</a>
            </small>
        </div>
    </div>
</article>
